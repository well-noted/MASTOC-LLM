# MASTOC-LLM Environment Variables
# Copy this file to .env and fill in your API keys.
# Only the keys for the backends you actually use are required.

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# OpenAI (GPT models)
OPENAI_API_KEY=

# Google (Gemini models)
GOOGLE_API_KEY=

# Ollama (local/self-hosted models)
# Default: http://localhost:11434 — change if running on a remote host
# OLLAMA_BASE_URL=http://localhost:11434
